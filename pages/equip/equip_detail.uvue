  align-items: stretch;
  border-radius: 20rpx;
  overflow: hidden;
  @apply flex flex-row  card mt-2;
}

/* 顶部 */
.header {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;

  @apply flex relative;

  .header-img {
    background: #eef2f6;
    @apply w-full h-full;
  }
}

.header-info {
  background: #ffffff;
  @apply flex flex-1 flex-col px-4 py-3;

  .device-name {
    @apply text-xl font-semibold text-slate-800 mb-4;
  }


  .header-info-item {
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    @apply flex flex-row justify-between mb-2;

    .name {
      @apply text-base text-slate-600;
    }

    .value {
      @apply text-xs font-medium text-slate-400;
    }
  }

  .workshop-name {
    @apply text-xs text-slate-500;
  }

  .device-sn {
    @apply text-xs text-slate-400;
  }

  .sn-wrap {
    @apply flex flex-row items-center gap-2;
  }

  .copy-btn {
    font-size: 22rpx;
    color: #2563eb;
    padding: 2rpx 10rpx;
    border-radius: 12rpx;
    background: rgba(37, 99, 235, 0.08);

    @apply active:opacity-70;
  }
}

.disabled {
  opacity: 0.30;
}

.disabled .icon-wrap {
  background: #f1f5f9;
}

.disabled .icon {
  color: #9ca3af;
}

.disabled .name {
  color: #9ca3af;
}

.operate-card {
  @apply flex flex-row card p-4;

  .operate-item {
    width: 20%;
    @apply flex flex-col items-center justify-center mr-5 ml-5;


    .icon-wrap {
      background: #f5f5f5;
      @apply w-12 h-12 flex rounded-full p-1 items-center justify-center;
    }

    .name {
      color: #6b7280;
      @apply text-sm mt-1;
    }
  }
}

/* 状态卡 */
.status-card {

  .status-item {
    @apply flex flex-row m-2 items-center w-full justify-between;

    .label {
      @apply ml-4 w-1/2 text-sm text-slate-600;
    }

    .dot {
      @apply flex w-3 h-3 rounded-full box-border mr-8
    }

  }
}

/* 属性 */
.attr-card {
  padding: 40rpx 40rpx 44rpx;

  .card-title {
    font-size: 40rpx;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 28rpx;
    display: block;
  }

  .attr-grid {
    @apply flex flex-row flex-wrap w-full;
    gap: 20rpx;

    .alarm-item {
      background: #ba0404;
      box-sizing: border-box;
      @apply rounded m-2 p-2;

      .value {
        color: #ffffff;
        @apply text-sm;
      }
    }

    .attr-item-clickable {
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .attr-item-clickable:active {
      opacity: 0.85;
    }

    .attr-item {
      width: calc(50% - 10rpx);
      min-height: 140rpx;
      background: #f5f6f8;
      box-sizing: border-box;
      position: relative;
      border-radius: 20rpx;
      padding: 28rpx 52rpx 28rpx 32rpx;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 12rpx;

      .attr-item-pin {
        position: absolute;
        top: 20rpx;
        right: 20rpx;
        opacity: 0.6;
        font-size: 40rpx;
      }

      .name {
        color: #64748b;
        font-size: 30rpx;
        padding-right: 32rpx;
      }

      .control-range {
        color: #94a3b8;
        font-size: 24rpx;
        margin-top: 4rpx;
      }

      .control-switch-row {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        gap: 24rpx;
      }

      .control-switch-label {
        display: flex;
        flex-direction: column;
        gap: 4rpx;
      }

      .control-type-tag {
        color: #94a3b8;
        font-size: 22rpx;
      }

      .value {
        font-weight: 600;
        line-height: 1.35;
        color: #0f172a;
        word-break: break-all;
        font-size: 38rpx;
        padding-right: 32rpx;
      }
    }
  }
}

/* 远程控制卡片 */
.ctrl-attr-card {
  .ctrl-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    width: 100%;
    gap: 20rpx;
  }

  .ctrl-item {
    width: calc(50% - 10rpx);
    min-height: 160rpx;
    background: #f5f6f8;
    box-sizing: border-box;
    border-radius: 20rpx;
    padding: 24rpx 28rpx;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
  }

  .ctrl-item-clickable {
    transition: opacity 0.2s;
  }

  .ctrl-item-clickable:active {
    opacity: 0.85;
  }

  .ctrl-item-name {
    color: #64748b;
    font-size: 28rpx;
    line-height: 1.4;
    margin-bottom: 16rpx;
  }

  .ctrl-item-value {
    font-weight: 600;
    font-size: 36rpx;
    color: #0f172a;
    line-height: 1.3;
    word-break: break-all;
  }

  .ctrl-item-value--switch {
    display: flex;
    align-items: center;
    margin-bottom: 0;
    min-height: 48rpx;
  }

  .ctrl-native-switch {
    transform: scale(0.72);
    transform-origin: left center;
  }
}

/* 操作 */
.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;

  .btn {
    flex: 1;
    border-radius: 40rpx;
  }

  .primary {
    background: #2563eb;
    border-radius: 32rpx;
    color: #fff;
  }
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1e293b;
}

.control-popup-wrap {
  border-radius: 24rpx;
  overflow: hidden;
  min-width: 560rpx;
  max-width: 90vw;
}

.control-popup-inner {
  padding: 0 32rpx 32rpx;
}

.control-popup-body {
  padding: 32rpx 0 28rpx;
}

.control-popup-hint {
  display: block;
  font-size: 28rpx;
