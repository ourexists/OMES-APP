<template>
  <scroll-view
      :style="{ flex: 1 }"
      scroll-y="true"
      scroll-x="false"
      :scroll-with-animation="true"
  >
    <cl-page>
      <cl-topbar
          fixed
          :background-color="isDark? 'black': 'white'"
          :show-back="true"
          safe-area-top
          :height="isMp() ? null : 100"
          :pt="{
    				className: '!z-50'
    			}"
      >
        <view
            class="flex flex-row items-center justify-center p-3 flex-1 w-full"
            :class="{
    					'pt-0': isMp()
    				}"
        >
          <!-- 当前选择展示 -->
          <cl-text
              color="primary"
              :pt="{
						className: '!text-xl ml-2'
					}"
          >
            {{ equip.name }}
          </cl-text>
        </view>
      </cl-topbar>
      <!-- ① 顶部设备头图 -->
      <view class="header-card card">
        <view class="header">
          <image
              :src="typeImage(equip)"
              mode="aspectFill"
              class="header-img"
          />

          <!-- 状态角标 -->
          <equip-badge :equip="equip" class="!text-xl"></equip-badge>
        </view>

        <!-- 名称 -->
        <view class="header-info">
          <text class="device-name">{{ equip!.name }}</text>
          <view class="header-info-item">
            <text class="name">{{ t('编号') }}</text>
            <view class="sn-wrap">
              <text class="device-sn">{{ equip!.selfCode }}</text>
              <text class="copy-btn" @tap="copySn">
                {{ t('复制') }}
              </text>
            </view>
          </view>
          <view class="header-info-item">
            <text class="name">{{ t('场景') }}</text>
            <text class="value">{{ equip!.workshop?.name }}</text>
          </view>
        </view>
      </view>

      <!-- ② 核心状态卡 -->
      <view class="status-card card">
        <view class="status-item">
          <text class="label">{{ t('在线状态') }}</text>
          <view class="dot shadow" :class="equip!.onlineState==1 ? 'online' : 'offline'"/>
        </view>

        <view class="status-item">
          <text class="label">{{ t('运行状态') }}</text>
          <view
              class="dot shadow"
              :class="equip!.onlineState==0 ? 'offline': equip!.runState == 1 ? 'run' : 'stopped'"
          />
        </view>

        <view class="status-item">
          <text class="label">{{ t('报警状态') }}</text>
          <view
              class="dot shadow"
              :class="equip!.onlineState==0 ? 'offline': equip!.alarmState == 1 ? 'alarm' : 'offline'"
          />
        </view>
      </view>
      <view class="card attr-card" v-if="equip!.alarmTexts != null && equip!.alarmTexts.length>0">
        <text class="card-title">{{ t('实时报警') }}</text>
        <view class="attr-grid">
          <view
              v-for="(i2, idx2) in equip!.alarmTexts"
              :key="idx2"
              class="alarm-item"
          >
            <text class="value">{{ i2 }}</text>
          </view>
        </view>
      </view>
      <view class="operate-card">
        <view class="operate-item"
              :class="{ disabled: equip!.attrs == null || equip!.attrs.length<=0 }"
              @tap="toEquipHistory">
          <view class="icon-wrap">
            <cl-icon name="hospital-line" class="icon"></cl-icon>
          </view>
          <text class="name">{{ t('历史') }}</text>
        </view>
      </view>
      <!-- ③ 实时属性 -->
      <view class="attr-card card" v-if="equip!.attrs != null && equip!.attrs.length>0">
        <text class="card-title">{{ t('实时数据') }}</text>
        <view class="attr-grid">
          <view
              v-for="(i, idx) in equip!.attrs"
              :key="idx"
              class="attr-item attr-item-clickable"
              @tap="openAttrChart(i)"
          >
            <cl-icon name="pushpin-line" class="attr-item-pin" color="primary" :pt="{ className: '!text-base' }"/>
            <text class="value">{{ attrValueWithUnit(i) }}</text>
            <text class="name">{{ i.name }}</text>
          </view>
        </view>
      </view>
      <!-- ④ 远程控制 -->
      <view class="attr-card card ctrl-attr-card" v-if="equip!.controls != null && equip!.controls.length>0">
        <text class="card-title">{{ t('远程控制') }}</text>
        <view class="ctrl-grid">
          <view
              v-for="(i, idx) in equip!.controls"
              :key="'ctrl-' + idx"
              class="ctrl-item"
              :class="{ 'ctrl-item-clickable': Number(i.type) === 1 }"
              @tap="onControlTap(i)"
          >
            <text class="ctrl-item-name">{{ i.name }}</text>
            <!-- 开关量：下方展示开关 (type 可能为数字 0 或字符串 "0") -->
            <view v-if="Number(i.type) === 0" class="ctrl-item-value ctrl-item-value--switch" @tap.stop>
              <switch
                  :checked="isControlOn(i)"
                  :disabled="controlWritingMap === i.map"
                  class="ctrl-native-switch"
                  @change="onSwitchChangeNative(i, $event)"
              />
            </view>
            <!-- 模拟量：下方展示值+单位 -->
            <text v-else class="ctrl-item-value">{{ controlValueWithUnit(i) }}</text>
          </view>
        </view>
      </view>
      <!-- 模拟量写入弹窗 -->
      <cl-popup
          ref="controlPopupRef"
          direction="center"
          :show-header="true"
          :show-close="true"
          :show-mask="true"
          @mask-close="closeControlPopup"
          :pt="{ className: 'control-popup-wrap' }"
      >
        <template #header>
          <text class="popup-title">{{ editingControl?.name }}</text>
        </template>
        <view class="control-popup-inner">
          <view class="control-popup-body">
            <text class="control-popup-hint" v-if="editingControl">{{
                t('请输入数值')
              }}{{
                editingControl.min != null && editingControl.max != null ? ` (${editingControl.min} ~ ${editingControl.max})` : ''
              }}
            </text>
            <cl-input
                v-if="editingControl"
                v-model="controlInputValue"
                type="digit"
                :placeholder="editingControl.value || ''"
                :pt="{ className: 'control-popup-input' }"
            />
          </view>
          <view class="control-popup-footer">
            <button class="control-popup-btn control-popup-btn--cancel" @tap="closeControlPopup">{{
                t('取消')
              }}
            </button>
            <button class="control-popup-btn control-popup-btn--primary" :disabled="controlSubmitting"
                    @tap="submitControlValue">{{ t('确定') }}
            </button>
          </view>
        </view>
      </cl-popup>
      // #ifdef MP
      <view class="card">
        <echart-equip-run :equip="equip"></echart-equip-run>
      </view>
      // #endif
    </cl-page>
  </scroll-view>
</template>

<script setup lang="ts">
import {ref} from 'vue'
import type {Equip, EquipAttr, EquipControl} from "@/core/types";
import {t} from "@/locale";
import {request} from "@/core/service";
import {apiPath} from "@/core/apiRouter/path";
import {parseData} from "@/core/utils/parse";
import EquipBadge from "@/pages/index/components/equip-badge.uvue";
import * as equipParser from '@/core/utils/equipParser';
import {isDark, isMp, router, useRefs, useUi} from "@/uni_modules/cool-unix";
// #ifdef MP
import EchartEquipRun from "@/pages/equip/components/echart-equip-run.uvue";
// #endif
const ui = useUi();
const refs = useRefs();
const controlPopupRef = ref<any>(null);
const editingControl = ref<EquipControl | null>(null);
const controlInputValue = ref('');
const controlSubmitting = ref(false);
/** 正在写入的控制点 map，用于开关 loading */
const controlWritingMap = ref<string | null>(null);

let equipId: string = ''
const equip = ref<Equip>({
  id: '-1',
  selfCode: '-1',
  name: t('无法识别'),
  type: 0,
  runState: 0,
  alarmState: 0,
  onlineState: 0
}) // 接接口获取

function attrValueWithUnit(attr: EquipAttr) {
  const val = attr.value == null ? t("暂未获取") : attr.value;
  const u = attr.unit;
  if (u != null && u !== '') return val + ' ' + u;
  return val;
}

function controlValueWithUnit(ctrl: EquipControl) {
  const val = ctrl.value == null ? t("暂未获取") : ctrl.value;
  const u = ctrl.unit;
  if (u != null && u !== '') return val + ' ' + u;
  return val;
}

/** 开关量当前是否为开 (value 为 '1' 或 'true') */
function isControlOn(ctrl: EquipControl): boolean {
  const v = ctrl.value;
  return v === '1' || v === 'true';
}

/** 开关量切换时调用 */
function onSwitchChange(ctrl: EquipControl, checked: boolean) {
  if (equip.value?.id == null) return;
  controlWritingMap.value = ctrl.map;
  writeControl(ctrl, checked ? 1 : 0).then(() => {
    controlWritingMap.value = null;
  }).catch(() => {
    controlWritingMap.value = null;
  });
}

/** 原生 switch 的 change 事件，取出 detail.value 后调用 onSwitchChange */
function onSwitchChangeNative(ctrl: EquipControl, ev: any) {
  const checked = ev && ev.detail && (ev.detail as { value?: boolean }).value;
  if (checked !== undefined) {
    onSwitchChange(ctrl, !!checked);
  }
}

function loadDetail() {
  request({
    url: apiPath.equip_realtime as string,
    method: "GET",
    data: {
      id: equipId,
    }
  }).then((res) => {
    if (res === null) {
      return;
    }
    let r = parseData<Equip>(res);
    if (r != null) {
      equip.value = r;
    }
  }).catch(() => {
  });
}

function copySn() {
  if (equip.value?.selfCode == null) {
    return;
  }

  uni.setClipboardData({
    data: equip.value.selfCode,
    success() {
      uni.showToast({
        title: t('已复制'),
        icon: 'success',
        duration: 1200
      });
    }
  });
}

function typeImage(equip: Equip | null | undefined): string {
  return equipParser.equipImage(equip);
}

onLoad((options) => {
  if (options == null) {
    return
  }
  equipId = options.id as string
  loadDetail()
})

function toEquipHistory() {
  if (equip.value!.attrs == null || equip.value!.attrs.length <= 0) {
    return;
  }
  router.to('/pages/equip/equip_collect?sn=' + equip.value.selfCode)
}

function openAttrChart(attr: EquipAttr) {
  if (equip.value?.selfCode == null || attr?.name == null) return
  const url = '/pages/equip/equip_collect?sn=' + encodeURIComponent(equip.value.selfCode) + '&attr=' + encodeURIComponent(attr.name)
  router.to(url)
}

/** type=0 开关量，type=1 模拟量 */
function onControlTap(ctrl: EquipControl) {
  if (Number(ctrl.type) === 0) return
  if (equip.value?.id == null) return
  if (Number(ctrl.type) === 1) {
    editingControl.value = ctrl
    controlInputValue.value = ctrl.value ?? ''
    controlPopupRef.value?.open?.()
  }
}

function closeControlPopup() {
  controlPopupRef.value?.close?.()
  editingControl.value = null
  controlInputValue.value = ''
}

function submitControlValue() {
  const ctrl = editingControl.value
  if (ctrl == null || equip.value?.id == null) {
    closeControlPopup()
    return
  }
  const val = controlInputValue.value.trim()
  if (val === '') {
    uni.showToast({title: t('请输入数值'), icon: 'none'})
    return
  }
  const num = Number(val)
  if (isNaN(num)) {
    uni.showToast({title: t('请输入有效数值'), icon: 'none'})
    return
  }
  const min = ctrl.min != null && ctrl.min !== '' ? Number(ctrl.min) : null
  const max = ctrl.max != null && ctrl.max !== '' ? Number(ctrl.max) : null
  if (min != null && num < min) {
    uni.showToast({title: t('不能小于') + ' ' + min, icon: 'none'})
    return
  }
  if (max != null && num > max) {
    uni.showToast({title: t('不能大于') + ' ' + max, icon: 'none'})
    return
  }
  controlSubmitting.value = true
  writeControl(ctrl, num).then(() => {
    controlSubmitting.value = false
    closeControlPopup()
  }).catch(() => {
    controlSubmitting.value = false
  })
}

/** 调用写控制接口：equipId, address=ctrl.map, value。request 在 code=200 时只 resolve(data)，不会带 code */
function writeControl(ctrl: EquipControl, value: number): Promise<void> {
  return request({
    url: apiPath.equip_write_control as string,
    method: 'POST',
    data: {
      equipId: equip.value!.id,
      address: ctrl.map,
      value: value
    }
  }).then(() => {
    setTimeout(() => {
      loadDetail()
    }, 1000)
  }).catch((err: any) => {
    uni.showToast({title: err?.msg || t('操作失败'), icon: 'none'})
  }).then(() => undefined) as Promise<void>
}

</script>


<style scoped lang="scss">
@import "../../static/equip";

.card {
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 6px 16px rgba(0, 0, 0, 0.06);
  @apply py-4 ml-4 mr-4 mb-4 rounded-2xl bg-white;
}

