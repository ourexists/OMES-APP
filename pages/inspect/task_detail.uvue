  margin-right: 20rpx;
  flex-shrink: 0;
}

.info-cell-icon :deep(.cl-icon) {
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-cell-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--cl-color-secondary);
  flex-shrink: 0;
}

.info-cell-value {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--cl-color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---------- 巡检模板卡片 ---------- */
.template-loading,
.template-empty {
  padding: 48rpx 32rpx;
  text-align: center;
  display: flex;
