}

/* ---------- 场景设备卡片 ---------- */
.devices-desc {
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  background: var(--cl-color-bg);
  border-radius: 12rpx;
  border: 1rpx dashed var(--cl-color-border);
}

.devices-loading,
.devices-empty {
  padding: 48rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.devices-empty :deep(.cl-icon),
.devices-loading :deep(.cl-icon) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.device-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 24rpx 24rpx 0;
  background: var(--cl-color-bg);
  border-radius: 20rpx;
  border: 1rpx solid var(--cl-color-border);
  position: relative;
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.15s;
}

.device-item:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.device-item.device-item--disabled {
  opacity: 0.7;
  pointer-events: none;
}

.device-item-accent {
  width: 6rpx;
  height: 100%;
  min-height: 72rpx;
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  border-radius: 20rpx 0 0 20rpx;
}

.device-item.is-run .device-item-accent {
  background: linear-gradient(180deg, #34c759 0%, #2da84a 100%);
}

.device-item.is-alarm .device-item-accent {
  background: linear-gradient(180deg, var(--cl-color-error) 0%, #e54535 100%);
}

.device-item.is-offline .device-item-accent {
  background: var(--cl-color-secondary);
  opacity: 0.6;
}

.device-item-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  box-sizing: content-box;
}

.device-item-main {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.device-name {
  font-size: 31rpx;
  font-weight: 600;
  color: var(--cl-color-primary);
}

.device-code {
  font-size: 24rpx;
  color: var(--cl-color-secondary);
}

.device-item-status {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-right: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
}

.status-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: inline-block;
  margin-right: 4rpx;
}

.status-dot.online {
  background: #34c759;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.25);
}

.status-dot.offline {
  background: var(--cl-color-secondary);
  opacity: 0.8;
}

.status-txt {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--cl-color-secondary);
  line-height: 1;
  display: inline-flex;
  align-items: center;
}

.device-item-inspected {
  font-size: 22rpx;
  color: #34c759;
  padding: 4rpx 12rpx;
  margin-right: 12rpx;
  background: rgba(52, 199, 89, 0.12);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.device-item-uninspected {
  font-size: 22rpx;
  color: var(--cl-color-secondary);
  padding: 4rpx 12rpx;
  margin-right: 12rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 8rpx;
  flex-shrink: 0;
}

.inspect-record-placeholder {
  margin-top: 28rpx;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 16rpx;
  border: 1rpx dashed var(--cl-color-border);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
</style>
