  color: var(--cl-color-primary);
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.plan-name-hero-badge {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
