  color: #fff;
  background: linear-gradient(135deg, #34c759 0%, #2da84a 100%);
  border: none;
  border-radius: 16rpx;
}

.complete-exec-btn[disabled] {
  opacity: 0.7;
}

.info-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-cell {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--cl-color-bg);
  border-radius: 16rpx;
  border: 1rpx solid var(--cl-color-border);
}

.info-cell-icon {
  width: 48rpx;
