  padding: 4rpx 0;

  @apply flex flex-row  items-center w-full justify-between;

  .desc {
    @apply text-sm;
  }
}


/* 圆点样式 */
.status-dot {
  box-shadow: 0 0 6px currentColor;
  @apply flex w-3 h-3 rounded-full box-border
}


/* 离线弱化 */
.device-card.is-offline {
  opacity: 0.6;
}

/* 报警红色边框 */
//.device-card.is-alarm {
//  border-color: #ff4d4f;
//  box-shadow: 0 0 6px rgba(255, 77, 79, 0.8);
//}

.device-card.is-alarm::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 4rpx;
  height: 100%;
  background: #f43f5e;
}

.device-card.is-offline {
  opacity: 0.45;
  filter: grayscale(0.6);
}

.status-summary {
  background: #020617;
  border: 1px solid rgba(148, 163, 184, 0.12);
  box-shadow: none;

  @apply flex justify-between bg-white rounded-xl m-2 items-center
}

.summary-item {
