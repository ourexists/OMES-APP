  color: #94a3b8;
  @apply text-xs font-extralight
}

.card-footer {
  background: transparent;
  padding: 3% 10% 5%;
}

/* 底部状态信息 */
.card-footer.column {
  @apply flex flex-col items-start mb-5;
}

//.status-item {
//  @apply flex flex-row  items-center w-full justify-between;
//
//  .desc {
//    @apply text-sm;
//  }
