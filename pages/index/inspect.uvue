<script lang="ts" setup>
import {config} from "@/config";
import {isDark, isMp, router, useRefs, useUi} from "@/uni_modules/cool-unix";
import LocaleSet from "@/components/locale-set.uvue";
import CustomTabbar from "@/components/tabbar.uvue";
import MsgNotifier from "@/components/msg-notifier.uvue";
import {t} from "@/locale";
import {useStore} from "@/core/store";
import {request} from "@/core/service";
import {apiPath} from "@/core/apiRouter/path";
import type {InspectTask} from "@/core/types";
import {parseData} from "@/core/utils/parse";
import {onMounted, ref} from "vue";

const ui = useUi();
const refs = useRefs();
const {user} = useStore();

const inspectTasks = ref<InspectTask[]>([]);
const inspectLoading = ref(false);
const inspectPage = ref(1);
const inspectPageSize = 50;
const inspectHasMore = ref(true);
const inspectLoadingMore = ref(false);

function setWorkshop() {
  router.to("/pages/equip/workshop_tree");
}

/** 加载当前账户名下的巡检任务（刷新，第一页） */
async function loadInspectTasks() {
  const accountId = user.info.value?.id;
  if (!accountId) {
    inspectTasks.value = [];
    return;
  }
  inspectLoading.value = true;
  inspectPage.value = 1;
  inspectHasMore.value = true;
  try {
    const res = await request({
      url: apiPath.inspect_task_page as string,
      method: "POST",
      data: {
        executorId: accountId,
        page: 1,
        pageSize: inspectPageSize
      }
    });
    if (res == null) {
      inspectTasks.value = [];
      return;
    }
    const list = Array.isArray(res) ? res : (res.list ?? res.data ?? []);
    inspectTasks.value = parseData<InspectTask[]>(list) ?? [];
    if ((inspectTasks.value?.length ?? 0) < inspectPageSize) inspectHasMore.value = false;
  } catch (_) {
    inspectTasks.value = [];
  } finally {
    inspectLoading.value = false;
  }
}

/** 上拉加载更多巡检任务 */
async function loadMoreInspectTasks() {
  const accountId = user.info.value?.id;
  if (!accountId || inspectLoadingMore.value || !inspectHasMore.value || inspectLoading.value) return;
  inspectLoadingMore.value = true;
  const nextPage = inspectPage.value + 1;
  try {
    const res = await request({
      url: apiPath.inspect_task_page as string,
      method: "POST",
      data: {
        executorId: accountId,
        page: nextPage,
        pageSize: inspectPageSize
      }
    });
    if (res == null) {
      inspectLoadingMore.value = false;
      return;
    }
    const list = Array.isArray(res) ? res : (res.list ?? res.data ?? []);
    const nextList = parseData<InspectTask[]>(list) ?? [];
    if (nextList.length > 0) {
      inspectTasks.value = (inspectTasks.value ?? []).concat(nextList);
      inspectPage.value = nextPage;
    }
    if (nextList.length < inspectPageSize) inspectHasMore.value = false;
  } catch (_) {
    // 静默失败，不再继续加载
    inspectHasMore.value = false;
  } finally {
    inspectLoadingMore.value = false;
  }
}

function openInspectTask(task: InspectTask) {
  router.to("/pages/inspect/task_detail?id=" + encodeURIComponent(task.id));
}

function inspectStatusClass(status: number | undefined): string {
  if (status === 0) return "status-pending";
  if (status === 1) return "status-progress";
  if (status === 2) return "status-completed";
  if (status === 3) return "status-overdue";
  return "";
}

function inspectStatusText(status: number | undefined): string {
  if (status === 0) return t("待执行");
  if (status === 1) return t("执行中");
  if (status === 2) return t("已完成");
  if (status === 3) return t("已逾期");
  return "";
}

function formatInspectTime(s: string): string {
  if (!s) return "";
  try {
    const d = new Date(s.replace(" ", "T"));
    const y = d.getFullYear();
    const m = (d.getMonth() + 1).toString().padStart(2, "0");
    const day = d.getDate().toString().padStart(2, "0");
    const h = d.getHours().toString().padStart(2, "0");
    const min = d.getMinutes().toString().padStart(2, "0");
    return `${y}-${m}-${day} ${h}:${min}`;
  } catch {
    return s;
  }
}

onMounted(() => {
  loadInspectTasks();
});

onShow(() => {
  if (user.info.value?.id) loadInspectTasks();
});

onPullDownRefresh(() => {
  loadInspectTasks().finally(() => {
    uni.stopPullDownRefresh();
  });
});

onReachBottom(() => {
  loadMoreInspectTasks();
});
</script>

<style lang="scss" scoped>
