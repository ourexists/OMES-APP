}

.inspect-load-more-txt {
  font-size: 24rpx;
  color: var(--cl-color-secondary);
}

.inspect-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 120rpx;
  padding: 28rpx 24rpx 28rpx 28rpx;
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
