}

.inspect-item-badge {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  font-weight: 500;
  border: 1rpx solid transparent;
}

.inspect-item-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.inspect-item-meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}

.inspect-item-meta-txt {
  font-size: 24rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态角标：与详情页一致（待执行灰、执行中橙、已完成绿、已逾期红） */
.inspect-item .inspect-item-badge.status-pending {
  background: rgba(99, 99, 102, 0.22);
  color: #636366;
  border-color: rgba(99, 99, 102, 0.25);
}

.inspect-item .inspect-item-badge.status-progress {
  background: rgba(255, 149, 0, 0.2);
  color: #ff9500;
  border-color: rgba(255, 149, 0, 0.25);
}

.inspect-item .inspect-item-badge.status-completed {
  background: rgba(52, 199, 89, 0.2);
  color: #34c759;
  border-color: rgba(52, 199, 89, 0.25);
}

.inspect-item .inspect-item-badge.status-overdue {
  background: rgba(255, 59, 48, 0.2);
  color: var(--cl-color-error, #ff3b30);
  border-color: rgba(255, 59, 48, 0.25);
}
</style>
