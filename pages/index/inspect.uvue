}

.inspect-item-overdue {
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04), 0 0 0 2rpx rgba(239, 68, 68, 0.08);
}

.inspect-item-status-bar {
  width: 6rpx;
  height: calc(100% - 24rpx);
  min-height: 64rpx;
  border-radius: 4rpx;
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 待执行：灰蓝色，与详情页一致 */
.inspect-item.status-pending .inspect-item-status-bar {
  background: linear-gradient(180deg, #636366 0%, #48484a 100%);
  box-shadow: 0 0 12rpx rgba(99, 99, 102, 0.3);
}

/* 执行中：橙色 */
.inspect-item.status-progress .inspect-item-status-bar {
  background: linear-gradient(180deg, #ff9500 0%, #e68600 100%);
  box-shadow: 0 0 16rpx rgba(255, 149, 0, 0.35);
}

/* 已完成：绿色 */
.inspect-item.status-completed .inspect-item-status-bar {
  background: linear-gradient(180deg, #34c759 0%, #2da84a 100%);
  box-shadow: 0 0 16rpx rgba(52, 199, 89, 0.35);
}

/* 已逾期：红色 */
.inspect-item.status-overdue .inspect-item-status-bar,
.inspect-item.inspect-item-overdue .inspect-item-status-bar {
  background: linear-gradient(180deg, #ff3b30 0%, #e54535 100%);
  box-shadow: 0 0 16rpx rgba(255, 59, 48, 0.4);
}

.inspect-item-body {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.inspect-item-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.inspect-item-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
