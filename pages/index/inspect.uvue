                  {{ inspectStatusText(task.status) }}
                </view>
              </view>
              <view class="inspect-item-meta">
                <!--                <view v-if="task.templateName" class="inspect-item-meta-row">-->
                <!--                  <cl-icon name="file-list-2-line" color="secondary" :pt="{ className: '!text-sm' }"/>-->
                <!--                  <text class="inspect-item-meta-txt">{{ task.templateName }}</text>-->
                <!--                </view>-->
                <view class="inspect-item-meta-row">
