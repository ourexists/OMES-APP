          </view>
          <!-- 上拉加载更多 -->
          <view v-if="inspectTasks.length > 0" class="inspect-load-more">
            <view v-if="inspectLoadingMore" class="inspect-load-more-inner">
              <cl-icon name="loader-4-line" color="secondary" :pt="{ className: '!text-base animate-spin mr-2' }"/>
              <text class="inspect-load-more-txt">{{ t('加载中...') }}</text>
            </view>
            <view v-else-if="!inspectHasMore" class="inspect-load-more-inner">
              <text class="inspect-load-more-txt">{{ t('没有更多了') }}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 自定义底部导航栏 -->
    <custom-tabbar></custom-tabbar>

    <!-- 主题设置 -->
