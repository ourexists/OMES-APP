        <!--                   color="primary"-->
        <!--                   :pt="{-->
        <!--						className: '!text-base mb-1'-->
        <!--					}"></cl-icon>-->
        <!--        </view>-->

        <!--        <view-->
        <!--            class="bg-primary-500 h-8 w-8 rounded-full flex flex-row items-center justify-center"-->
        <!--            :class="{-->
        <!--						'mr-24': isMp()-->
        <!--					}"-->
        <!--            @tap="setLocale"-->
        <!--        >-->
        <!--          <cl-icon name="translate" color="white"></cl-icon>-->
        <!--        </view>-->
      </view>
    </cl-topbar>
    <view class="mainContainer">
      <msg-notifier class="msg-notifier"></msg-notifier>

      <!-- 巡检工单 -->
      <view class="inspect-page">
        <!--        <view class="inspect-section-head">-->
        <!--          <view class="inspect-section-head-line"></view>-->
        <!--          <text class="inspect-section-head-title">{{ t('巡检工单') }}</text>-->
        <!--          <text v-if="!inspectLoading && inspectTasks.length > 0" class="inspect-section-head-count">{{ inspectTasks.length }}</text>-->
        <!--        </view>-->
        <view v-if="inspectLoading" class="inspect-state-wrap">
          <view class="inspect-state-inner">
            <view class="inspect-loading-dot"></view>
            <cl-icon name="loader-4-line" color="secondary" :pt="{ className: 'animate-spin' }"/>
