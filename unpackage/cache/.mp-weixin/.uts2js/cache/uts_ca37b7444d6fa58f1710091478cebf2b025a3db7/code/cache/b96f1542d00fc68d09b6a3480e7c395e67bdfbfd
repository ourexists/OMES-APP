{"code":"export class Touch {\n    constructor() {\n        // 触摸起始Y坐标\n        this.startY = 0;\n        // 触摸起始X坐标\n        this.startX = 0;\n        // 横向滑动参数\n        this.horizontal = 0;\n    }\n    start(e) {\n        this.startX = e.touches[0].clientX;\n        this.startY = e.touches[0].clientY;\n        this.horizontal = 0;\n    }\n    move(e) {\n        const x = this.startX - e.touches[0].clientX;\n        if (this.horizontal == 0) {\n            // 只在horizontal=0时判断一次\n            const y = this.startY - e.touches[0].clientY;\n            if (Math.abs(x) > Math.abs(y)) {\n                // 如果x轴移动距离大于y轴移动距离则表明是横向移动手势\n                this.horizontal = 1;\n            }\n            if (this.horizontal == 1) {\n                // 如果是横向移动手势，则阻止默认行为（防止页面滚动）\n                e.preventDefault();\n            }\n        }\n    }\n    end() {\n        this.startY = 0;\n        this.horizontal = 0;\n    }\n}\nexport function useTouch() {\n    return new Touch();\n}\n//# sourceMappingURL=E:/project/iot/omes/OMES-app/uni_modules/cool-unix/hooks/touch.js.map","references":[],"uniExtApis":[],"map":"{\"version\":3,\"file\":\"touch.js\",\"sourceRoot\":\"\",\"sources\":[\"touch.ts\"],\"names\":[],\"mappings\":\"AAAA,MAAM,OAAO,KAAK;IAAlB;QACC,UAAU;QACV,WAAM,GAAG,CAAC,CAAC;QACX,UAAU;QACV,WAAM,GAAG,CAAC,CAAC;QACX,SAAS;QACT,eAAU,GAAG,CAAC,CAAC;IA+BhB,CAAC;IA7BA,KAAK,CAAC,CAAgB;QACrB,IAAI,CAAC,MAAM,GAAG,CAAC,CAAC,OAAO,CAAC,CAAC,CAAC,CAAC,OAAO,CAAC;QACnC,IAAI,CAAC,MAAM,GAAG,CAAC,CAAC,OAAO,CAAC,CAAC,CAAC,CAAC,OAAO,CAAC;QACnC,IAAI,CAAC,UAAU,GAAG,CAAC,CAAC;IACrB,CAAC;IAED,IAAI,CAAC,CAAgB;QACpB,MAAM,CAAC,GAAG,IAAI,CAAC,MAAM,GAAG,CAAC,CAAC,OAAO,CAAC,CAAC,CAAC,CAAC,OAAO,CAAC;QAE7C,IAAI,IAAI,CAAC,UAAU,IAAI,CAAC,EAAE;YACzB,sBAAsB;YACtB,MAAM,CAAC,GAAG,IAAI,CAAC,MAAM,GAAG,CAAC,CAAC,OAAO,CAAC,CAAC,CAAC,CAAC,OAAO,CAAC;YAE7C,IAAI,IAAI,CAAC,GAAG,CAAC,CAAC,CAAC,GAAG,IAAI,CAAC,GAAG,CAAC,CAAC,CAAC,EAAE;gBAC9B,6BAA6B;gBAC7B,IAAI,CAAC,UAAU,GAAG,CAAC,CAAC;aACpB;YAED,IAAI,IAAI,CAAC,UAAU,IAAI,CAA