<template>
  <cl-footer
      :pt="{
			content: {
				className: '-important-p-0 h--bracket-start-60px-bracket-end-'
			}
		}"
   >
    <view class="custom-tabbar" :class="{ 'is-dark': isDark }">
      <view
          class="custom-tabbar-item"
          v-for="item in list"
          :key="item.pagePath"
          @tap="router.to(item.pagePath)"
       >
        <cl-image
            :src="path == item.pagePath ? item.icon2 : item.icon"
            :height="56"
            :width="56"
         ></cl-image>
        <text
            v-if="item.pagePath.includes('message') && unread_count  > 0"
            class="badge"
        >
          {{ unread_count > 99 ? '99+' : unread_count }}
        </text>

        <!-- 未读角标 -->

        <cl-text
            v-if="item.text != null"
            :pt="{
						className: parseClass([
							'text-xs mt-1',
							[path == item.pagePath, 'text-primary-500', 'text-surface-400']
						])
					}"
         >{{ t(item.text!) }}
        </cl-text
        >
      </view>
    </view>
  </cl-footer>
</template>

<script setup lang="ts">
import {ctx, isDark, parseClass, router} from "@/uni_modules/cool-unix";
import {t} from "@/locale";

import {computed} from "vue";
import {unread_count} from "@/components/msg-notifier";

defineOptions({
  name: "custom-tabbar"
});

type Item = {
  icon: string;
  icon2: string;
  pagePath: string;
  text: string | null;
};

const path = computed(() => router.path());

// tabbar 列表
const list = computed<Item[]>(() => {
  return (ctx.tabBar.list ?? []).map((e) => {
    return {
      icon: e.iconPath!,
      icon2: e.selectedIconPath!,
      pagePath: e.pagePath,
      text: t(e.text?.replaceAll("%", "")!)
    } as Item;
  });
});

// 隐藏原生 tabBar

if (ctx.tabBar.list != null) {
  uni.hideTabBar();
}

</script>

<style lang="scss" scoped>
.custom-tabbar {
  @apply flex flex-row items-center flex-1;
  &-item {
    @apply flex flex-col items-center justify-center flex-1;
  }
}

.icon-wrapper {
  position: relative;
}

.badge {
  position: absolute;
  top: 0rpx;
  right: 40rpx;
  min-width: 32rpx;
  height: 32rpx;
  //padding: 0 6rpx;

  background-color: #f44336;
  color: #fff;

  font-size: 20rpx;
  line-height: 32rpx;
  text-align: center;

  box-sizing: border-box;

  @apply rounded-full
}
</style>
