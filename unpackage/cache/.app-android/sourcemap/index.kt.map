<script lang="ts">
import {useStore} from "@/core/store";
import {router} from '@/uni_modules/cool-unix'
import {connectMessage, disconnectMessage} from "@/components/msg-notifier";








export default {
  onLaunch: function () {
    console.log("App Launch");
    if (router.isLoginPage(router.path())) return;

    const {user} = useStore()
    if (user.isUnLogin()) {
      console.log("未登陆");
      user.logout();
      return;
    }
    connectMessage();
  },
  onShow: function () {
    console.log("App Show");
    // 根据业务情况判断是否要预先调用
    if (router.isLoginPage(router.path())) return;

    const {user} = useStore();
    if (user.isUnLogin()) {
      console.log("未登陆");
      user.logout();
      return;
    }
    //刷新用户信息
    user.get();
    connectMessage()
  },
  onHide: function () {
    disconnectMessage();
  },
  onExit: function () {
    disconnectMessage();
  },
};
</script>

