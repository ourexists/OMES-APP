<template>
  <scroll-view
      :style="{ flex: 1 }"
      scroll-y="true"
      scroll-x="false"
      :scroll-with-animation="true"
   >
    <cl-page >
      <cl-topbar
          fixed
          :background-color="isDark? 'black': 'white'"
          :show-back="true"
          safe-area-top
          :height="isMp() ? null : 100"
          :pt="{
    				className: '-important-z-50'
    			}"
       >
        <view
            class="flex flex-row items-center justify-center p-3 flex-1 w-full"
            :class="{
    					'pt-0': isMp()
    				}"
        >
          <!-- 当前选择展示 -->
          <cl-text
              color="primary"
              :pt="{
						className: '-important-text-xl ml-2'
					}"
           >
            {{ equip.name }}
          </cl-text>
        </view>
      </cl-topbar>
      <!-- ① 顶部设备头图 -->
      <view class="header-card card" >
        <view class="header" >
          <image
              :src="typeImage(equip)"
              mode="aspectFill"
              class="header-img"
           />

          <!-- 状态角标 -->
          <equip-badge :equip="equip" class="-important-text-xl" ></equip-badge>
        </view>

        <!-- 名称 -->
        <view class="header-info" >
          <text class="device-name" >{{ equip!.name }}</text>
          <view class="header-info-item" >
            <text class="name" >{{ t('编号') }}</text>
            <view class="sn-wrap" >
              <text class="device-sn" >{{ equip!.selfCode }}</text>
              <text class="copy-btn" @tap="copySn" >
                {{ t('复制') }}
              </text>
            </view>
          </view>
          <view class="header-info-item" >
            <text class="name" >{{ t('场景') }}</text>
            <text class="value" >{{ equip!.workshop?.name }}</text>
          </view>
        </view>
      </view>

      <!-- ② 核心状态卡 -->
      <view class="status-card card" >
        <view class="status-item" >
          <text class="label" >{{ t('在线状态') }}</text>
          <view class="dot shadow" :class="equip!.onlineState==1 ? 'online' : 'offline'"/>
        </view>

        <view class="status-item" >
          <text class="label" >{{ t('运行状态') }}</text>
          <view
              class="dot shadow"
              :class="equip!.onlineState==0 ? 'offline': equip!.runState == 1 ? 'run' : 'stopped'"
          />
        </view>

        <view class="status-item" >
          <text class="label" >{{ t('报警状态') }}</text>
          <view
              class="dot shadow"
              :class="equip!.onlineState==0 ? 'offline': equip!.alarmState == 1 ? 'alarm' : 'offline'"
          />
        </view>
      </view>
      <view class="card attr-card" v-if="equip!.alarmTexts != null && equip!.alarmTexts.length >0">
        <text class="card-title" >{{ t('实时报警') }}</text>
        <view class="attr-grid" >
          <view
              v-for="(i2, idx2) in equip!.alarmTexts"
              :key="idx2"
              class="alarm-item"
           >
            <text class="value" >{{ i2 }}</text>
          </view>
        </view>
      </view>
      <view class="operate-card" >
        <view class="operate-item"
              :class="{ disabled: equip!.attrs == null || equip!.attrs.length<=0 }"
              @tap="toEquipHistory">
          <view class="icon-wrap" >
            <cl-icon name="hospital-line" class="icon" ></cl-icon>
          </view>
          <text class="name" >{{ t('历史') }}</text>
        </view>
      </view>
      <!-- ③ 实时属性 -->
      <view class="attr-card card" v-if="equip!.attrs != null && equip!.attrs.length >0">
        <text class="card-title" >{{ t('实时数据') }}</text>
        <view class="attr-grid" >
          <view
              v-for="(i, idx) in equip!.attrs"
              :key="idx"
              class="attr-item attr-item-clickable"
              @tap="openAttrChart(i)"
           >
            <cl-icon name="pushpin-line" class="attr-item-pin" color="primary" :pt="{ className: '-important-text-base' }"  />
            <text class="value" >{{ attrValueWithUnit(i) }}</text>
            <text class="name" >{{ i.name }}</text>
          </view>
        </view>
      </view>





    </cl-page>
  </scroll-view>
</template>

<script setup lang="ts">
import {ref} from 'vue'
import type {Equip, EquipAttr} from "@/core/types";
import {t} from "@/locale";
import {request} from "@/core/service";
import {apiPath} from "@/core/apiRouter/path";
import {parseData} from "@/core/utils/parse";
import EquipBadge from "@/pages/index/components/equip-badge.uvue";
import * as equipParser from '@/core/utils/equipParser';
import {isDark, isMp, router, useRefs, useUi} from "@/uni_modules/cool-unix";



const ui = useUi();
const refs = useRefs();

let equipId: string = ''
const equip = ref<Equip>({
  id: '-1',
  selfCode: '-1',
  name: t('无法识别'),
  type: 0,
  runState: 0,
  alarmState: 0,
  onlineState: 0
}) // 接接口获取

function attrValueWithUnit(attr: EquipAttr) {
  const val = attr.value == null ? t("暂未获取") : attr.value;
  const u = attr.unit;
  if (u != null && u !== '') return val + ' ' + u;
  return val;
}

function loadDetail() {
  request({
    url: apiPath.equip_realtime as string,
    method: "GET",
    data: {
      id: equipId,
    }
  }).then((res) => {
    if (res === null) {
      return;
    }
    let r = parseData<Equip>(res);
    if (r != null) {
      equip.value = r;
    }
  });
}

function copySn() {
  if (equip.value?.selfCode == null) {
    return;
  }

  uni.setClipboardData({
    data: equip.value.selfCode,
    success() {
      uni.showToast({
        title: t('已复制'),
        icon: 'success',
        duration: 1200
      });
    }
  });
}

function typeImage(equip: Equip): string {
  return equipParser.equipImage(equip);
}

onLoad((options) => {
  if (options == null) {
    return
  }
  equipId = options.id as string
  loadDetail()
})

function toEquipHistory() {
  if (equip.value!.attrs == null || equip.value!.attrs.length <= 0) {
    return;
  }
  router.to('/pages/equip/equip_collect?sn=' + equip.value.selfCode)
}

function openAttrChart(attr: EquipAttr) {
  if (equip.value?.selfCode == null || attr?.name == null) return
  const url = '/pages/equip/equip_collect?sn=' + encodeURIComponent(equip.value.selfCode) + '&attr=' + encodeURIComponent(attr.name)
  router.to(url)
}

</script>


<style scoped lang="scss">
@import "../../static/equip";

.card {
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 6px 16px rgba(0, 0, 0, 0.06);
  @apply py-4 ml-4 mr-4 mb-4 rounded-2xl bg-white;
}

.header-card {
  align-items: stretch;
  border-radius: 20rpx;
  overflow: hidden;
  @apply flex flex-row  card mt-2;
}

/* 顶部 */
.header {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;

  @apply flex relative;

  .header-img {
    background: #eef2f6;
    @apply w-full h-full;
  }
}

.header-info {
  background: #ffffff;
  @apply flex flex-1 flex-col px-4 py-3;

  .device-name {
    @apply text-xl font-semibold text-slate-800 mb-4;
  }


  .header-info-item {
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    @apply flex flex-row justify-between mb-2;

    .name {
      @apply text-base text-slate-600;
    }

    .value {
      @apply text-xs font-medium text-slate-400;
    }
  }

  .workshop-name {
    @apply text-xs text-slate-500;
  }

  .device-sn {
    @apply text-xs text-slate-400;
  }

  .sn-wrap {
    @apply flex flex-row items-center gap-2;
  }

  .copy-btn {
    font-size: 22rpx;
    color: #2563eb;
    padding: 2rpx 10rpx;
    border-radius: 12rpx;
    background: rgba(37, 99, 235, 0.08);

    @apply active:opacity-70;
  }
}

.disabled {
  opacity: 0.30;
}

.disabled .icon-wrap {
  background: #f1f5f9;
}

.disabled .icon {
  color: #9ca3af;
}

.disabled .name {
  color: #9ca3af;
}

.operate-card {
  @apply flex flex-row card p-4;

  .operate-item {
    width: 20%;
    @apply flex flex-col items-center justify-center mr-5 ml-5;


    .icon-wrap {
      background: #f5f5f5;
      @apply w-12 h-12 flex rounded-full p-1 items-center justify-center;
    }

    .name {
      color: #6b7280;
      @apply text-sm mt-1;
    }
  }
}

/* 状态卡 */
.status-card {

  .status-item {
    @apply flex flex-row m-2 items-center w-full justify-between;

    .label {
      @apply ml-4 w-1/2 text-sm text-slate-600;
    }

    .dot {
      @apply flex w-3 h-3 rounded-full box-border mr-8
    }

  }
}

/* 属性 */
.attr-card {
  padding: 40rpx 40rpx 44rpx;

  .card-title {
    font-size: 40rpx;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 28rpx;
    display: block;
  }

  .attr-grid {
    @apply flex flex-row flex-wrap w-full;
    gap: 20rpx;

    .alarm-item {
      background: #ba0404;
      box-sizing: border-box;
      @apply rounded m-2 p-2;

      .value {
        color: #ffffff;
        @apply text-sm;
      }
    }

    .attr-item-clickable {
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .attr-item-clickable:active {
      opacity: 0.85;
    }
    .attr-item {
      width: calc(50% - 10rpx);
      min-height: 140rpx;
      background: #f5f6f8;
      box-sizing: border-box;
      position: relative;
      border-radius: 20rpx;
      padding: 28rpx 52rpx 28rpx 32rpx;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      gap: 12rpx;

      .attr-item-pin {
        position: absolute;
        top: 20rpx;
        right: 20rpx;
        opacity: 0.6;
        font-size: 40rpx;
      }

      .name {
        color: #64748b;
        font-size: 30rpx;
        padding-right: 32rpx;
      }

      .value {
        font-weight: 600;
        line-height: 1.35;
        color: #0f172a;
        word-break: break-all;
        font-size: 38rpx;
        padding-right: 32rpx;
      }
    }
  }
}

/* 操作 */
.action-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;

  .btn {
    flex: 1;
    border-radius: 40rpx;
  }

  .primary {
    background: #2563eb;
    border-radius: 32rpx;
    color: #fff;
  }
}

</style>
