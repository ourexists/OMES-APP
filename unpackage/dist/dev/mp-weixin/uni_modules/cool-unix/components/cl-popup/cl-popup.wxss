.cl-popup-wrapper.data-v-09d8aefc {
  height: 100%;
  width: 100%;
  position: fixed;
  top: 0px;
  bottom: 0px;
  left: 0px;
  right: 0px;
  pointer-events: none;
}
.cl-popup-wrapper .cl-popup-mask.data-v-09d8aefc {
  position: absolute;
  top: 0px;
  bottom: 0px;
  left: 0px;
  right: 0px;
  height: 100%;
  width: 100%;
  background-color: rgba(0, 0, 0, 1);
  opacity: 0;
  transition-property: opacity;
}
.cl-popup-wrapper .cl-popup-mask.is-open.data-v-09d8aefc {
  opacity: 0.4;
}
.cl-popup-wrapper .cl-popup-mask.is-open.data-v-09d8aefc, .cl-popup-wrapper .cl-popup-mask.is-close.data-v-09d8aefc {
  transition-duration: 0.3s;
}
.cl-popup-wrapper .cl-popup.data-v-09d8aefc {
  position: absolute;
  transition-duration: 300ms;
  transition-property: transform;
}
.cl-popup-wrapper .cl-popup__inner.data-v-09d8aefc {
  display: flex;
  height: 100%;
  width: 100%;
  flex-direction: column;
  background-color: rgba(255, 255, 255, 1);
}
.cl-popup-wrapper .cl-popup__inner.is-dark.data-v-09d8aefc {
  background-color: rgba(63, 63, 70, 1);
}
.cl-popup-wrapper .cl-popup__draw.data-v-09d8aefc {
  border-radius: 10.5rpx;
  background-color: rgba(228, 228, 231, 1);
  position: absolute;
  top: 14rpx;
  left: 50%;
  height: 10rpx;
  width: 70rpx;
  transform: translateX(-50%);
  transition-property: background-color;
  transition-duration: 0.2s;
}
.cl-popup-wrapper .cl-popup__header.data-v-09d8aefc {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  height: 90rpx;
  padding: 0 80rpx 0 26rpx;
}
.cl-popup-wrapper .cl-popup__container.data-v-09d8aefc {
  flex: 1;
}
.cl-popup-wrapper .cl-popup.stop-transition.data-v-09d8aefc {
  transition-property: none;
}
.cl-popup-wrapper--left .cl-popup.data-v-09d8aefc {
  left: 0px;
  top: 0px;
  transform: translateX(-100%);
}
.cl-popup-wrapper--left .cl-popup.is-open.data-v-09d8aefc {
  transform: translateX(0);
}
.cl-popup-wrapper--right .cl-popup.data-v-09d8aefc {
  right: 0px;
  top: 0px;
  transform: translateX(100%);
}
.cl-popup-wrapper--right .cl-popup.is-open.data-v-09d8aefc {
  transform: translateX(0);
}
.cl-popup-wrapper--top .cl-popup.data-v-09d8aefc {
  left: 0px;
  top: 0px;
  transform: translateY(-100%);
}
.cl-popup-wrapper--top .cl-popup .cl-popup__inner.data-v-09d8aefc {
  border-bottom-right-radius: 28rpx;
  border-bottom-left-radius: 28rpx;
}
.cl-popup-wrapper--top .cl-popup.is-open.data-v-09d8aefc {
  transform: translateY(0);
}
.cl-popup-wrapper--left > .cl-popup.is-custom-navbar.data-v-09d8aefc, .cl-popup-wrapper--right > .cl-popup.is-custom-navbar.data-v-09d8aefc, .cl-popup-wrapper--top > .cl-popup.is-custom-navbar.data-v-09d8aefc {
  top: 0;
}
.cl-popup-wrapper--bottom > .cl-popup.data-v-09d8aefc {
  left: 0px;
  bottom: 0px;
  transform: translateY(100%);
}
.cl-popup-wrapper--bottom > .cl-popup .cl-popup__inner.data-v-09d8aefc {
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
}
.cl-popup-wrapper--bottom > .cl-popup.is-open.data-v-09d8aefc {
  transform: translateY(0);
}
.cl-popup-wrapper--bottom > .cl-popup.is-close.data-v-09d8aefc {
  transform: translateY(100%);
}
.cl-popup-wrapper--center.data-v-09d8aefc {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.cl-popup-wrapper--center > .cl-popup.data-v-09d8aefc {
  transform: scale(1.3);
  opacity: 0;
  transition-property: transform, opacity;
}
.cl-popup-wrapper--center > .cl-popup .cl-popup__inner.data-v-09d8aefc {
  border-radius: 28rpx;
}
.cl-popup-wrapper--center > .cl-popup.is-open.data-v-09d8aefc {
  transform: translate(0, 0) scale(1);
  opacity: 1;
}