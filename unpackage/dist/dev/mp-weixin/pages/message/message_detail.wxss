.content-wrapper.data-v-696000ff {
  height: calc(100vh - 120rpx);
}
.detail-card.data-v-696000ff {
  border-radius: 21rpx;
  background-color: rgba(255, 255, 255, 1);
  padding: 42rpx;
  box-shadow: rgba(0, 0, 0, 0.1);
}
.card-type1.data-v-696000ff {
  border: 2px solid #ba0404;
}
.detail-header.data-v-696000ff {
  margin-bottom: 42rpx;
  display: flex;
  align-items: center;
}
.detail-icon.data-v-696000ff {
  margin-right: 28rpx;
  height: 84rpx;
  width: 84rpx;
  align-items: center;
}
.detail-meta.data-v-696000ff {
  margin-top: 35rpx;
  display: flex;
  flex-direction: column;
}
.detail-title.data-v-696000ff {
  margin-bottom: 7rpx;
  display: flex;
  width: 100%;
  text-align: center;
  font-size: 42rpx;
  line-height: 56rpx;
  font-weight: 700;
}
.message-source.data-v-696000ff {
  margin-bottom: 35rpx;
  display: flex;
  width: 100%;
  flex-direction: row;
  align-items: center;
  border-radius: 7rpx;
  border-style: solid;
  border-color: rgba(243, 244, 246, 1);
  background-color: rgba(255, 255, 255, 1);
  padding: 14rpx;
}
.message-source-middle.data-v-696000ff {
  flex: 1;
  padding-right: 14rpx;
  padding-left: 14rpx;
}
.message-source-left.data-v-696000ff {
  flex: 0 0 auto;
  height: 100%;
  width: 28rpx;
  align-items: center;
  justify-content: center;
  padding: 21rpx;
}
.message-source-right.data-v-696000ff {
  flex: 0 0 auto;
  height: 100%;
  width: 35rpx;
}
.detail-time.data-v-696000ff {
  display: flex;
  text-align: center;
  font-size: 24.5rpx;
  line-height: 35rpx;
  color: rgba(107, 114, 128, 1);
}
.detail-content.data-v-696000ff {
  white-space: pre-wrap;
  font-size: 28rpx;
  line-height: 42rpx;
  line-height: 1.625;
}