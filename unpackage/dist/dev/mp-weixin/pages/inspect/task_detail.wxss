/* ---------- 页面与顶栏 ---------- */
.detail-scroll.data-v-b0fd5180 {
  flex: 1;
  padding: 10rpx;
  background: var(--detail-page-bg, var(--cl-color-bg));
}
.data-v-b0fd5180 .detail-topbar {
  border-bottom: 1rpx solid var(--cl-color-border);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ---------- 卡片通用 ---------- */
.detail-card.data-v-b0fd5180 {
  background: var(--cl-color-bg-elevated);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--cl-color-border);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}
.card-head.data-v-b0fd5180 {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}
.card-head-icon.data-v-b0fd5180 {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.card-head-icon.data-v-b0fd5180 .cl-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-head-icon.task-icon.data-v-b0fd5180 {
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.15) 0%, rgba(0, 122, 255, 0.06) 100%);
  color: var(--cl-color-primary);
}
.card-head-icon.template-icon.data-v-b0fd5180 {
  background: linear-gradient(135deg, rgba(88, 86, 214, 0.15) 0%, rgba(88, 86, 214, 0.06) 100%);
  color: #5856d6;
}
.card-head-icon.devices-icon.data-v-b0fd5180 {
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.15) 0%, rgba(52, 199, 89, 0.06) 100%);
  color: #34c759;
}
.detail-card-title.data-v-b0fd5180 {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--cl-color-primary);
  letter-spacing: 0.5rpx;
}

/* ---------- 任务信息卡片 ---------- */
.plan-name-hero.data-v-b0fd5180 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  margin: 0 -28rpx 24rpx -28rpx;
  border-radius: 0;
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.08) 0%, rgba(0, 122, 255, 0.03) 100%);
  border-left: 6rpx solid var(--cl-color-primary);
}

/* 待执行：灰蓝色区分，未开始 */
.plan-name-hero.status-pending.data-v-b0fd5180 {
  background: linear-gradient(135deg, rgba(99, 99, 102, 0.1) 0%, rgba(99, 99, 102, 0.04) 100%);
  border-left-color: #636366;
}
.plan-name-hero.status-progress.data-v-b0fd5180 {
  background: linear-gradient(135deg, rgba(255, 149, 0, 0.08) 0%, rgba(255, 149, 0, 0.03) 100%);
  border-left-color: #ff9500;
}
.plan-name-hero.status-completed.data-v-b0fd5180 {
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.08) 0%, rgba(52, 199, 89, 0.03) 100%);
  border-left-color: #34c759;
}
.plan-name-hero.status-overdue.data-v-b0fd5180 {
  background: linear-gradient(135deg, rgba(255, 59, 48, 0.08) 0%, rgba(255, 59, 48, 0.03) 100%);
  border-left-color: var(--cl-color-error);
}
.plan-name-hero-text.data-v-b0fd5180 {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--cl-color-primary);
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.plan-name-hero-badge.data-v-b0fd5180 {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}
.plan-name-hero-badge.status-pending.data-v-b0fd5180 {
  background: rgba(99, 99, 102, 0.22);
  color: #636366;
}
.plan-name-hero-badge.status-progress.data-v-b0fd5180 {
  background: rgba(255, 149, 0, 0.2);
  color: #ff9500;
}
.plan-name-hero-badge.status-completed.data-v-b0fd5180 {
  background: rgba(52, 199, 89, 0.2);
  color: #34c759;
}
.plan-name-hero-badge.status-overdue.data-v-b0fd5180 {
  background: rgba(255, 59, 48, 0.2);
  color: var(--cl-color-error);
}
.confirm-exec-wrap.data-v-b0fd5180 {
  margin-top: 24rpx;
  padding: 0 0 8rpx;
}
.confirm-exec-btn.data-v-b0fd5180 {
  width: 100%;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #007aff 0%, #0051d5 100%);
  border: none;
  border-radius: 16rpx;
}
.confirm-exec-btn-bracket-start-disabled-bracket-end-.data-v-b0fd5180 {
  opacity: 0.7;
}
.complete-exec-wrap.data-v-b0fd5180 {
  margin-top: 24rpx;
  padding: 0 0 8rpx;
}
.complete-exec-btn.data-v-b0fd5180 {
  width: 100%;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #34c759 0%, #2da84a 100%);
  border: none;
  border-radius: 16rpx;
}
.complete-exec-btn-bracket-start-disabled-bracket-end-.data-v-b0fd5180 {
  opacity: 0.7;
}
.info-grid.data-v-b0fd5180 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.info-cell.data-v-b0fd5180 {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--cl-color-bg);
  border-radius: 16rpx;
  border: 1rpx solid var(--cl-color-border);
}
.info-cell-icon.data-v-b0fd5180 {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.info-cell-icon.data-v-b0fd5180 .cl-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
.info-cell-label.data-v-b0fd5180 {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--cl-color-secondary);
  flex-shrink: 0;
}
.info-cell-value.data-v-b0fd5180 {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--cl-color-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---------- 巡检模板卡片 ---------- */
.template-loading.data-v-b0fd5180,
.template-empty.data-v-b0fd5180 {
  padding: 48rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.template-empty.data-v-b0fd5180 .cl-icon {
  display: block;
}
.template-content.data-v-b0fd5180 {
  margin-top: 8rpx;
}
.template-name-pill.data-v-b0fd5180 {
  display: inline-block;
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, rgba(88, 86, 214, 0.12) 0%, rgba(88, 86, 214, 0.05) 100%);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(88, 86, 214, 0.2);
}
.template-name-pill-text.data-v-b0fd5180 {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--cl-color-primary);
}
.template-remark.data-v-b0fd5180 {
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}
.template-items-title.data-v-b0fd5180 {
  font-size: 26rpx;
  color: var(--cl-color-secondary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}
.template-items.data-v-b0fd5180 {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.template-item-row.data-v-b0fd5180 {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 22rpx 24rpx;
  background: var(--cl-color-bg);
  border-radius: 16rpx;
  border: 1rpx solid var(--cl-color-border);
  transition: background 0.2s;
}
.template-item-row-alt.data-v-b0fd5180 {
  background: rgba(0, 0, 0, 0.02);
}
.template-item-num.data-v-b0fd5180 {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(88, 86, 214, 0.2) 0%, rgba(88, 86, 214, 0.08) 100%);
  color: #5856d6;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.template-item-main.data-v-b0fd5180 {
  flex: 1;
  min-width: 0;
}
.template-item-name.data-v-b0fd5180 {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--cl-color-primary);
  display: block;
  margin-bottom: 10rpx;
}
.template-item-meta.data-v-b0fd5180 {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}
.template-item-type-tag.data-v-b0fd5180 {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.template-item-type-tag.type-1.data-v-b0fd5180 {
  background: rgba(88, 86, 214, 0.12);
  color: #5856d6;
}
.template-item-type-tag.type-2.data-v-b0fd5180 {
  background: rgba(52, 199, 89, 0.12);
  color: #34c759;
}
.template-item-type-tag.type-3.data-v-b0fd5180 {
  background: rgba(255, 149, 0, 0.12);
  color: #ff9500;
}
.template-item-unit.data-v-b0fd5180 {
  font-size: 24rpx;
  color: var(--cl-color-secondary);
}
.template-items-empty.data-v-b0fd5180 {
  padding: 32rpx 0;
  text-align: center;
}

/* ---------- 场景设备卡片 ---------- */
.devices-desc.data-v-b0fd5180 {
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  background: var(--cl-color-bg);
  border-radius: 12rpx;
  border: 1rpx dashed var(--cl-color-border);
}
.devices-loading.data-v-b0fd5180,
.devices-empty.data-v-b0fd5180 {
  padding: 48rpx 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.devices-empty.data-v-b0fd5180 .cl-icon,
.devices-loading.data-v-b0fd5180 .cl-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.device-list.data-v-b0fd5180 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.device-item.data-v-b0fd5180 {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 24rpx 24rpx 0;
  background: var(--cl-color-bg);
  border-radius: 20rpx;
  border: 1rpx solid var(--cl-color-border);
  position: relative;
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.15s;
}
.device-item-colon-active.data-v-b0fd5180 {
  transform: scale(0.99);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.device-item.device-item--disabled.data-v-b0fd5180 {
  opacity: 0.7;
  pointer-events: none;
}
.device-item-accent.data-v-b0fd5180 {
  width: 6rpx;
  height: 100%;
  min-height: 72rpx;
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  border-radius: 20rpx 0 0 20rpx;
}
.device-item.is-run .device-item-accent.data-v-b0fd5180 {
  background: linear-gradient(180deg, #34c759 0%, #2da84a 100%);
}
.device-item.is-alarm .device-item-accent.data-v-b0fd5180 {
  background: linear-gradient(180deg, var(--cl-color-error) 0%, #e54535 100%);
}
.device-item.is-offline .device-item-accent.data-v-b0fd5180 {
  background: var(--cl-color-secondary);
  opacity: 0.6;
}
.device-item-icon.data-v-b0fd5180 {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  box-sizing: content-box;
}
.device-item-main.data-v-b0fd5180 {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.device-name.data-v-b0fd5180 {
  font-size: 31rpx;
  font-weight: 600;
  color: var(--cl-color-primary);
}
.device-code.data-v-b0fd5180 {
  font-size: 24rpx;
  color: var(--cl-color-secondary);
}
.device-item-status.data-v-b0fd5180 {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-right: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 12rpx;
}
.status-dot.data-v-b0fd5180 {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: inline-block;
  margin-right: 4rpx;
}
.status-dot.online.data-v-b0fd5180 {
  background: #34c759;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.25);
}
.status-dot.offline.data-v-b0fd5180 {
  background: var(--cl-color-secondary);
  opacity: 0.8;
}
.status-txt.data-v-b0fd5180 {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--cl-color-secondary);
  line-height: 1;
  display: inline-flex;
  align-items: center;
}
.device-item-inspected.data-v-b0fd5180 {
  font-size: 22rpx;
  color: #34c759;
  padding: 4rpx 12rpx;
  margin-right: 12rpx;
  background: rgba(52, 199, 89, 0.12);
  border-radius: 8rpx;
  flex-shrink: 0;
}
.device-item-uninspected.data-v-b0fd5180 {
  font-size: 22rpx;
  color: var(--cl-color-secondary);
  padding: 4rpx 12rpx;
  margin-right: 12rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 8rpx;
  flex-shrink: 0;
}
.inspect-record-placeholder.data-v-b0fd5180 {
  margin-top: 28rpx;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 16rpx;
  border: 1rpx dashed var(--cl-color-border);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}