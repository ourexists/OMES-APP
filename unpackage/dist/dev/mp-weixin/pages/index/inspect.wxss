/* 白色科技感：浅色渐变 + 微妙网格感 */
.mainContainer.data-v-caaf3101 {
  position: relative;
  width: 100%;
  padding-bottom: 28rpx;
  padding-top: 16rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f0f4f8 0%, #ffffff 18%, #fafbfd 100%);
  background-attachment: local;
}
.msg-notifier.data-v-caaf3101 {
  position: absolute;
  top: 70rpx;
}

/* 巡检区块 */
.inspect-page.data-v-caaf3101 {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 70vh;
  padding: 0 24rpx 32rpx;
}

/* 区块标题：左侧科技感竖线 + 标题 + 数量角标 */
.inspect-section-head.data-v-caaf3101 {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}
.inspect-section-head-line.data-v-caaf3101 {
  width: 6rpx;
  height: 32rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #22c55e 0%, #16a34a 100%);
  margin-right: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(34, 197, 94, 0.35);
}
.inspect-section-head-title.data-v-caaf3101 {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: 0.5rpx;
}
.inspect-section-head-count.data-v-caaf3101 {
  margin-left: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  background: rgba(34, 197, 94, 0.12);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* 空态 / 加载态 */
.inspect-state-wrap.data-v-caaf3101 {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 60vh;
  padding: 48rpx 32rpx;
}
.inspect-state-inner.data-v-caaf3101 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}
.inspect-loading-dot.data-v-caaf3101 {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, calc(-50% - 40rpx));
}
.inspect-empty-icon-wrap.data-v-caaf3101 {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%);
  border: 1rpx solid rgba(34, 197, 94, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  color: var(--cl-color-secondary);
}

/* 工单列表：卡片式 */
.inspect-list.data-v-caaf3101 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 0 24rpx;
}
.inspect-load-more.data-v-caaf3101 {
  padding: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.inspect-load-more-inner.data-v-caaf3101 {
  display: flex;
  align-items: center;
  justify-content: center;
}
.inspect-load-more-txt.data-v-caaf3101 {
  font-size: 24rpx;
  color: var(--cl-color-secondary);
}
.inspect-item.data-v-caaf3101 {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 120rpx;
  padding: 28rpx 24rpx 28rpx 28rpx;
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04), 0 1rpx 0 rgba(255, 255, 255, 0.8) inset;
  transition: box-shadow 0.2s, transform 0.2s;
}
.inspect-item-colon-active.data-v-caaf3101 {
  transform: scale(0.99);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.inspect-item-overdue.data-v-caaf3101 {
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04), 0 0 0 2rpx rgba(239, 68, 68, 0.08);
}
.inspect-item-status-bar.data-v-caaf3101 {
  width: 6rpx;
  height: calc(100% - 24rpx);
  min-height: 64rpx;
  border-radius: 4rpx;
  position: absolute;
  left: 16rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 待执行：灰蓝色，与详情页一致 */
.inspect-item.status-pending .inspect-item-status-bar.data-v-caaf3101 {
  background: linear-gradient(180deg, #636366 0%, #48484a 100%);
  box-shadow: 0 0 12rpx rgba(99, 99, 102, 0.3);
}

/* 执行中：橙色 */
.inspect-item.status-progress .inspect-item-status-bar.data-v-caaf3101 {
  background: linear-gradient(180deg, #ff9500 0%, #e68600 100%);
  box-shadow: 0 0 16rpx rgba(255, 149, 0, 0.35);
}

/* 已完成：绿色 */
.inspect-item.status-completed .inspect-item-status-bar.data-v-caaf3101 {
  background: linear-gradient(180deg, #34c759 0%, #2da84a 100%);
  box-shadow: 0 0 16rpx rgba(52, 199, 89, 0.35);
}

/* 已逾期：红色 */
.inspect-item.status-overdue .inspect-item-status-bar.data-v-caaf3101,
.inspect-item.inspect-item-overdue .inspect-item-status-bar.data-v-caaf3101 {
  background: linear-gradient(180deg, #ff3b30 0%, #e54535 100%);
  box-shadow: 0 0 16rpx rgba(255, 59, 48, 0.4);
}
.inspect-item-body.data-v-caaf3101 {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}
.inspect-item-top.data-v-caaf3101 {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.inspect-item-title.data-v-caaf3101 {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.inspect-item-badge.data-v-caaf3101 {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  font-weight: 500;
  border: 1rpx solid transparent;
}
.inspect-item-meta.data-v-caaf3101 {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.inspect-item-meta-row.data-v-caaf3101 {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}
.inspect-item-meta-txt.data-v-caaf3101 {
  font-size: 24rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态角标：与详情页一致（待执行灰、执行中橙、已完成绿、已逾期红） */
.inspect-item .inspect-item-badge.status-pending.data-v-caaf3101 {
  background: rgba(99, 99, 102, 0.22);
  color: #636366;
  border-color: rgba(99, 99, 102, 0.25);
}
.inspect-item .inspect-item-badge.status-progress.data-v-caaf3101 {
  background: rgba(255, 149, 0, 0.2);
  color: #ff9500;
  border-color: rgba(255, 149, 0, 0.25);
}
.inspect-item .inspect-item-badge.status-completed.data-v-caaf3101 {
  background: rgba(52, 199, 89, 0.2);
  color: #34c759;
  border-color: rgba(52, 199, 89, 0.25);
}
.inspect-item .inspect-item-badge.status-overdue.data-v-caaf3101 {
  background: rgba(255, 59, 48, 0.2);
  color: var(--cl-color-error, #ff3b30);
  border-color: rgba(255, 59, 48, 0.25);
}