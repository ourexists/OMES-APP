  box-sizing: border-box;
  display: flex;
  border-radius: 9999px;
}
.status-summary.data-v-310265e9 {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  margin: 12rpx 24rpx;
