  font-weight: 600;
  color: #334155;
  line-height: 1.3;
  margin-top: 2rpx;
  text-align: center;
}
.summary-item .status-dot.data-v-310265e9 {
  border: 1px solid rgba(0, 0, 0, 0.08);
  width: 28rpx;
  height: 28rpx;
  min-width: 28rpx;
  min-height: 28rpx;
  margin-bottom: 6rpx;
  flex-shrink: 0;
  overflow: visible;
  box-shadow: 0 0 6rpx currentColor;
  box-sizing: border-box;
  display: flex;
  border-radius: 9999px;
  border-width: 1px;
}
.summary-item.data-v-310265e9 {
  cursor: pointer;
