  font-size: 22rpx;
  margin-top: 4rpx;
}
.card-status-row.data-v-310265e9 {
  margin-top: 12rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx 24rpx;
}
.card-dot.data-v-310265e9 {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  box-shadow: 0 0 4rpx currentColor;
