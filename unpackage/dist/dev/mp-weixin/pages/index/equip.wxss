  overflow: hidden;
}
.card-img.data-v-310265e9 {
  width: 100%;
  height: 100%;
  opacity: 0.92;
  display: block;
  object-fit: cover;
}
.card-info.data-v-310265e9 {
  flex: 1;
  min-width: 0;
  padding: 16rpx 20rpx;
