}
.card-name.data-v-310265e9 {
  color: #1e293b;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-workshop.data-v-310265e9 {
  color: #64748b;
  font-size: 24rpx;
  margin-top: 8rpx;
}
.card-sn.data-v-310265e9 {
