/* 视图切换按钮内图标居中 */
.view-mode-btn.data-v-310265e9 {
  flex-shrink: 0;
}
.view-mode-btn.data-v-310265e9 .cl-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}
/* 卡片列表 */
.device-card-list.data-v-310265e9 {
  padding: 24rpx;
  margin-bottom: 28rpx;
  display: flex;
  flex-direction: column;
}
.device-card.data-v-310265e9 {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  transition: border-color 0.2s ease;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: 12rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}
.device-card-list .device-card-colon-last-child.data-v-310265e9 {
  margin-bottom: 0;
}
.device-card.is-run.data-v-310265e9 {
  border-color: rgba(82, 196, 26, 0.35);
}
.device-card.is-alarm-colon--colon-before.data-v-310265e9 {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 6rpx;
  height: 100%;
  background: #f43f5e;
  z-index: 1;
}
.device-card.is-offline.data-v-310265e9 {
  opacity: 0.65;
}
/* 上：左图右信息 */
.card-main.data-v-310265e9 {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 160rpx;
  border-radius: 12rpx;
