  overflow: visible;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx 0;
}
.summary-item.data-v-310265e9 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  /* 约 44px，满足最小触控区域 */
  min-width: 80rpx;
  overflow: visible;
}
.summary-item-col.data-v-310265e9 {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.summary-item-txt.data-v-310265e9 {
  font-size: 22rpx;
  color: #334155;
